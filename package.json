{
  "name": "obsidian-bamboo-review",
  "version": "2.4.1",
  "description": "竹林修仙传 - Obsidian 每日复盘插件",
  "main": "main.js",
  "scripts": {
    "dev": "npm run build:webapp && tsc --noEmit && node esbuild.config.mjs",
    "build": "npm run build:webapp && tsc --noEmit -skipLibCheck && npm run lint && node esbuild.config.mjs production",
    "build:webapp": "node scripts/bundle-webapp.mjs",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:host": "vitest run",
    "lint": "eslint .",
    "lint:css": "node scripts/lint-css-tokens.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"webapp/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"webapp/**/*.js\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.24.2",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "obsidian": "^1.8.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "fflate": "^0.8.3"
  }
}
